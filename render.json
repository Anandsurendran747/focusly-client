{
  "services": [
    {
      "type": "web",
      "name": "focusly-client",
      "env": "static",
      "buildCommand": "npm run build",
      "staticPublishPath": "./build",
      "routes": [
        {
          "type": "rewrite",
          "source": "/*",
          "destination": "/index.html"
        }
      ]
    }
  ]
}